---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { useTranslations } from '../i18n/translations';

const lang = 'en';
const t = useTranslations(lang);
const marqueeItems = [
  'Brand Strategy', 'Digital Marketing', 'Visual Identity',
  'Web Design', 'Growth Hacking', 'Content Creation',
  'Marketing Intelligence', 'Design Thinking',
];
---

<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  lang={lang}
>
  <style is:global>
    body { min-height: 100vh; }
    h1, h2, h3, .font-display { font-family: 'Outfit', sans-serif; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #000; }
    ::-webkit-scrollbar-thumb { background: var(--color-brand); border-radius: 4px; }

    .bg-grid {
      background-image:
        linear-gradient(rgba(232, 0, 61, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232, 0, 61, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    /* Animation for the floating line */
    @keyframes scanline {
      0% { transform: translateY(-100%); opacity: 0; }
      50% { opacity: 1; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    .scanner {
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--color-brand), transparent);
      animation: scanline 8s linear infinite;
    }
  </style>

    <!-- Header / Nav -->
    <header class="fixed top-0 inset-x-0 z-50 px-6 py-4 flex justify-between items-center backdrop-blur-md bg-black/20"
              style="border-bottom: 1px solid rgba(255,255,255,0.06);"
              role="banner">

        <div class="flex flex-col justify-center gap-1">
          <img
            src="/assets/brand/aglaya-logo-blanco.svg"
            alt="AGLAYA"
            height="28"
            loading="eager"
          />
          <span class="text-[6px] font-black tracking-[0.3em] text-muted uppercase pl-0.5">THE UNCOMFORTABLE AGENCY</span>
        </div>

        <div class="flex items-center gap-4">
          <a
            href="https://wa.me/573224288532"
            target="_blank"
            rel="noopener noreferrer"
            class="brand-cta bg-brand hover:bg-brand-hover text-white px-2 py-2 text-[10px] font-bold tracking-widest uppercase transition-all hover:scale-105 active:scale-95 flex items-center gap-2 rounded-sm shadow-[0_0_20px_rgba(232,0,61,0.3)]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            <span>WhatsApp</span>
          </a>
          <a
            href="/es/"
            lang="es"
            hreflang="es"
            class="lang-flag flex items-center gap-1 px-1 py-1.5 hover:border-brand/40 transition-all text-[10px] font-black tracking-widest text-muted hover:text-white group"
            aria-label="Ver en Español"
          >
            <div class="w-10 h-10 rounded-full overflow-hidden border border-white/10 flex items-center justify-center shrink-0">
              <img src="/assets/brand/spain.svg" alt="España" width="24" height="24" class="w-full h-full object-cover" loading="eager" />
            </div>
          </a>
        </div>
    </header>

    <main class="relative min-h-screen bg-black text-white selection:bg-brand selection:text-white">

    <!-- Hero Section -->
    <section class="relative pt-20 pb-20 px-6 min-h-[90vh] flex items-center z-30 overflow-hidden"
             aria-labelledby="hero-heading">
      
      <!-- Phantom Text background -->
      <div class="absolute right-[10%] top-1/2 -translate-y-1/2 select-none pointer-events-none z-0 opacity-10 hidden lg:block">
        <div class="text-[300px] font-black leading-none flex flex-col items-end tracking-tighter"
             style="-webkit-text-stroke: 2px white; color: transparent;">
          <span>AG</span>
          <span>LA</span>
          <span>YA</span>
        </div>
      </div>

      <div class="container pt-5 max-w-7xl relative z-10 flex flex-col lg:flex-row items-center lg:items-center">
        <div class="w-full lg:w-3/5 text-center lg:text-left">
          <div class="mb-8 flex flex-col items-center lg:items-start">
            <div class="h-px w-24 bg-brand mb-6"></div>
            <span class="text-xs font-black tracking-[0.5em] text-brand-light uppercase mb-4 decoration-brand/30 underline-offset-8 ">COMING SOON</span>
          </div>

          <h1 id="hero-heading" class="text-6xl md:text-8xl lg:text-8xl font-black tracking-tighter mb-12 leading-[0.85] uppercase">
            <span class="block text-white mb-2">The</span>
            <span class="relative py-2 block">
              <span class="relative z-10 text-brand italic">Uncomfortable</span>
            </span>
              <span class="relative z-10 text-white">Agency</span>
          </h1>

          <!-- Form Area -->
          <div class="w-full max-w-md mx-auto lg:mx-0 p-8 bg-white/5 border border-white/10 backdrop-blur-xl relative group rounded-sm shadow-2xl">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-brand/20 to-purple-500/20 rounded-sm blur opacity-50 group-hover:opacity-100 transition duration-1000"></div>
            <div class="relative">
              <ContactForm lang={lang} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee Tech Stack -->
    <div class="fixed bottom-0 inset-x-0 z-40 bg-black/80 backdrop-blur-lg border-t border-white/5 py-4 overflow-hidden" role="complementary">
      <div class="flex whitespace-nowrap animate-marquee">
        {marqueeItems.concat(marqueeItems).map((item) => (
          <span class="text-[10px] font-black tracking-[0.4em] uppercase text-muted hover:text-brand transition-colors mx-8 block">
            {item}
          </span>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .text-brand { color: var(--color-brand); }
  .text-brand-light { color: #FF4D70; }
  .text-muted { color: rgba(255, 255, 255, 0.5); }
  .bg-brand { background-color: var(--color-brand); }
  .bg-black { background-color: #000; }
</style>
