import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { Image } from 'astro:assets';
import logoSvg from '../assets/images/aglaya-logo.svg';
import { useTranslations } from '../i18n/translations';

const lang = 'en';
const t = useTranslations(lang);
const marqueeItems = [
  'Brand Strategy', 'Digital Marketing', 'Visual Identity',
  'Web Design', 'Growth Hacking', 'Content Creation',
  'Marketing Intelligence', 'Design Thinking',
];
---

<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  lang={lang}
>
  <style is:global>
    body { overflow: hidden; }
    h1, h2, h3, .font-display { font-family: 'Outfit', sans-serif; }
    ::-webkit-scrollbar { display: none; }

    .bg-grid {
      background-image:
        linear-gradient(rgba(232, 0, 61, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232, 0, 61, 0.04) 1px, transparent 1px);
      background-size: 48px 48px;
    }

    @keyframes scan {
      0%   { transform: translateY(-100%); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    .scan-line { animation: scan 6s linear infinite; }

    .glass {
      background: rgba(17, 17, 17, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.07);
    }

    /* Flag switcher */
    .lang-flag {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(245,245,245,0.45);
      text-decoration: none;
      padding: 4px 10px;
      border: 1px solid rgba(255,255,255,0.1);
      transition: all 0.2s;
    }
    .lang-flag:hover {
      color: #f5f5f5;
      border-color: rgba(255,255,255,0.3);
    }
    .lang-flag .flag { font-size: 16px; line-height: 1; }

    a.brand-cta:hover { background: #b5002f !important; }
    a.text-link:hover { color: #e8003d; }
  </style>

  <div id="app" class="relative flex h-screen w-screen flex-col overflow-hidden" style="background:#080808;">

    <!-- Background: mesh + grid + scan -->
    <div class="mesh-gradient"></div>
    <div class="bg-grid absolute inset-0 z-0 pointer-events-none"></div>
    <div class="scan-line absolute left-0 right-0 h-px z-10 pointer-events-none"
         style="background: linear-gradient(90deg, transparent, rgba(232,0,61,0.6), transparent);"></div>

    <div class="relative flex h-full w-full flex-col z-10">

      <!-- ══ HEADER ══ -->
      <header class="w-full flex items-center justify-between px-6 py-4 md:px-12 shrink-0"
              style="border-bottom: 1px solid rgba(255,255,255,0.06);"
              role="banner">

        <div class="flex flex-col justify-center gap-1">
          <Image
            src={logoSvg}
            alt="AGLAYA"
            height={28}
            class="h-6 md:h-7 w-auto object-contain"
            loading="eager"
          />
          <span class="font-display font-light uppercase tracking-[0.25em]"
                style="font-size: 0.55rem; color: #e8003d; letter-spacing: 0.25em;">
            THE UNCOMFORTABLE AGENCY
          </span>
        </div>

        <!-- Nav -->
        <nav class="flex items-center gap-4" aria-label="Main navigation">
          <a
            href="/es/"
            lang="es"
            hreflang="es"
            class="lang-flag flex items-center gap-2 px-3 py-1.5 border border-white/10 hover:border-brand/40 transition-all text-[10px] font-black tracking-widest text-muted hover:text-white group"
            aria-label="Ver en Español"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 group-hover:text-brand transition-colors" aria-hidden="true"><path d="m5 8 6 6 6-6"/><path d="m4 14 8-8 8 8"/></svg>
            <span>ES</span>
          </a>
          <a
            href="https://wa.me/573224288532"
            target="_blank"
            rel="noopener noreferrer"
            class="brand-cta hidden md:inline-flex items-center gap-2 px-5 py-2 text-[10px] font-black uppercase tracking-widest text-white transition-all active:scale-95"
            style="background: #e8003d;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            WhatsApp
          </a>
        </nav>
      </header>

      <!-- ══ MAIN ══ -->
      <main class="flex-1 flex items-center px-6 md:px-12 lg:px-20 min-h-0" id="main-content">
        <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- LEFT — Copy + CTA -->
          <div class="flex flex-col justify-center">
            <span class="inline-block font-display font-black text-xs uppercase tracking-[0.3em] mb-6"
                  style="color: #e8003d;"
                  aria-label="Coming Soon">
              {t('hero.label')}
            </span>

            <h1 class="font-display font-black uppercase leading-[0.88] mb-6"
                style="font-size: clamp(3rem, 8vw, 7rem); color: #f5f5f5;">
              The<br/>
              <span class="text-brand">uncomfortable</span><br/>
              agency.
            </h1>

            <p class="text-sm md:text-base leading-relaxed mb-8 max-w-md"
               style="color: rgba(245,245,245,0.55);">
              {t('hero.subtext')}
            </p>

            <div class="glass p-6 max-w-md">
              <ContactForm lang="en" />
            </div>
          </div>

          <!-- RIGHT — Decorative typographic letterform -->
          <div class="hidden lg:flex items-center justify-center relative" aria-hidden="true">
            <div class="absolute w-80 h-80 rounded-full animate-glow pointer-events-none"
                 style="border: 1px solid rgba(232, 0, 61, 0.15); box-shadow: 0 0 120px rgba(232, 0, 61, 0.08);"></div>
            <div class="absolute w-56 h-56 rounded-full pointer-events-none"
                 style="border: 1px solid rgba(232, 0, 61, 0.08);"></div>
            <div class="font-display font-black uppercase leading-none select-none text-center relative z-10"
                 style="font-size: clamp(6rem, 14vw, 12rem); color: transparent; -webkit-text-stroke: 1px rgba(232,0,61,0.35);">
              AG<br/>LA<br/>YA
            </div>
          </div>

        </div>
      </main>

      <!-- ══ MARQUEE ══ -->
      <section class="w-full shrink-0 py-3 overflow-hidden"
               style="border-top: 1px solid rgba(255,255,255,0.06);"
               aria-label="Services">
        <div class="animate-marquee gap-12" aria-hidden="true">
          <div class="flex items-center gap-12 text-[11px] md:text-xs font-black uppercase tracking-widest"
               style="color: rgba(245,245,245,0.35);">
            {marqueeItems.map((item) => (
              <><span>{item}</span><span style="color:#e8003d;">•</span></>
            ))}
          </div>
          <div class="flex items-center gap-12 text-[11px] md:text-xs font-black uppercase tracking-widest"
               style="color: rgba(245,245,245,0.35);" aria-hidden="true">
            {marqueeItems.map((item) => (
              <><span>{item}</span><span style="color:#e8003d;">•</span></>
            ))}
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
