---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/hero-abstract.png';
import { useTranslations } from '../i18n/translations';

const lang = 'en';
const t = useTranslations(lang);
const marqueeItems = [
  'Brand Strategy', 'Digital Marketing', 'Visual Identity',
  'Web Design', 'Growth Hacking', 'Content Creation',
  'Marketing Intelligence', 'Design Thinking',
];
---

<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  lang={lang}
>
  <style is:global>
    body { overflow: hidden; }

    /* Outfit as the display/heading font */
    h1, h2, h3, .font-display {
      font-family: 'Outfit', sans-serif;
    }

    /* Scrollbar hidden */
    ::-webkit-scrollbar { display: none; }

    /* Gradient grid overlay */
    .bg-grid {
      background-image:
        linear-gradient(rgba(232, 0, 61, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232, 0, 61, 0.04) 1px, transparent 1px);
      background-size: 48px 48px;
    }

    /* Animated line */
    @keyframes scan {
      0%   { transform: translateY(-100%); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 1; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    .scan-line {
      animation: scan 6s linear infinite;
    }

    /* Glass panel */
    .glass {
      background: rgba(17, 17, 17, 0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.07);
    }

    /* Brand hover */
    a.brand-link:hover { color: #e8003d; }
  </style>

  <div class="relative flex h-screen w-screen flex-col overflow-hidden" style="background:#080808;">

    <!-- Background grid -->
    <div class="bg-grid absolute inset-0 z-0 pointer-events-none"></div>

    <!-- Scan line -->
    <div class="scan-line absolute left-0 right-0 h-px z-0 pointer-events-none" style="background: linear-gradient(90deg, transparent, rgba(232,0,61,0.6), transparent);"></div>

    <!-- Hero image — full bleed, very dark overlay -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <Image
        src={heroImage}
        alt=""
        format="webp"
        class="w-full h-full object-cover opacity-25"
        aria-hidden="true"
      />
      <!-- Dark vignette so text stays readable -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, transparent 20%, #080808 80%);"></div>
    </div>

    <!-- Z-layer for all content -->
    <div class="relative flex h-full w-full flex-col z-10">

      <!-- ══ HEADER ══ -->
      <header
        class="w-full flex items-center justify-between px-6 py-4 md:px-12 shrink-0"
        style="border-bottom: 1px solid rgba(255,255,255,0.06);"
      >
        <!-- Logo wordmark -->
        <div class="flex flex-col leading-none select-none">
          <span
            class="font-display font-black uppercase tracking-[0.25em] text-white"
            style="font-size: clamp(1.1rem, 2.5vw, 1.6rem); letter-spacing: 0.3em;"
          >AGLAYA</span>
          <span
            class="font-display font-light uppercase tracking-[0.3em] text-xs"
            style="color: #e8003d; font-size: clamp(0.5rem, 1vw, 0.65rem);"
          >LA AGENCIA INCÓMODA</span>
        </div>

        <!-- Language switcher + contact -->
        <nav class="flex items-center gap-6" aria-label="Main navigation">
          <a
            href="/es/"
            lang="es"
            hreflang="es"
            class="brand-link text-[10px] font-bold tracking-widest uppercase transition-colors"
            style="color: rgba(245,245,245,0.45);"
          >ES</a>
          <a
            href="mailto:hola@aglaya.biz"
            class="brand-link hidden md:inline-block text-xs font-bold tracking-widest uppercase transition-colors"
            style="color: rgba(245,245,245,0.45);"
          >{t('nav.contact')}</a>
          <a
            href="https://wa.me/34600000000"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden md:inline-flex items-center gap-2 px-5 py-2 text-xs font-black uppercase tracking-widest text-white transition-all active:scale-95"
            style="background: #e8003d;"
          >WhatsApp</a>
        </nav>
      </header>

      <!-- ══ MAIN ══ -->
      <main class="flex-1 flex items-center px-6 md:px-12 lg:px-20 min-h-0" id="main-content">
        <div class="w-full max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

          <!-- LEFT — Copy + CTA -->
          <div class="flex flex-col justify-center">

            <!-- Label -->
            <span
              class="inline-block font-display font-black text-xs uppercase tracking-[0.3em] mb-6"
              style="color: #e8003d;"
              aria-label="Coming Soon"
            >
              {t('hero.label')}
            </span>

            <!-- Headline -->
            <h1
              class="font-display font-black uppercase leading-[0.88] mb-6"
              style="font-size: clamp(3rem, 8vw, 7rem); color: #f5f5f5;"
            >
              The<br/>
              <span style="color: #e8003d;">uncomfort</span><wbr/>able<br/>
              agency.
            </h1>

            <!-- Subtext -->
            <p
              class="text-sm md:text-base leading-relaxed mb-8 max-w-md"
              style="color: rgba(245,245,245,0.55);"
            >
              {t('hero.subtext')}
            </p>

            <!-- Lead form -->
            <div class="glass p-6 max-w-md">
              <LeadForm lang="en" />

              <!-- Divider -->
              <div
                class="flex items-center gap-3 my-4"
                style="border-top: 1px solid rgba(255,255,255,0.07); padding-top: 1rem;"
              >
                <span class="text-[10px] uppercase tracking-widest font-bold" style="color: rgba(245,245,245,0.35);">
                  {t('contact.label')}
                </span>
              </div>

              <!-- Direct contacts -->
              <div class="flex flex-wrap gap-4 text-sm font-bold">
                <a
                  href="mailto:hola@aglaya.biz"
                  class="brand-link underline underline-offset-4 transition-colors"
                  style="color: rgba(245,245,245,0.7);"
                >hola@aglaya.biz</a>
                <a
                  href="https://wa.me/34600000000"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 transition-colors brand-link"
                  style="color: rgba(245,245,245,0.7);"
                >
                  <span class="material-symbols-outlined text-base" aria-hidden="true">chat</span>
                  WhatsApp
                </a>
              </div>
            </div>
          </div>

          <!-- RIGHT — Abstract visual (desktop only) -->
          <div class="hidden lg:flex items-center justify-center relative">
            <!-- Glowing ring decoration -->
            <div
              class="absolute w-80 h-80 rounded-full animate-glow pointer-events-none"
              style="border: 1px solid rgba(232, 0, 61, 0.15); box-shadow: 0 0 120px rgba(232, 0, 61, 0.08);"
            ></div>
            <div
              class="absolute w-56 h-56 rounded-full pointer-events-none"
              style="border: 1px solid rgba(232, 0, 61, 0.08);"
            ></div>

            <!-- Large typographic element -->
            <div
              class="font-display font-black uppercase leading-none select-none text-center relative z-10"
              style="font-size: clamp(6rem, 14vw, 12rem); color: transparent; -webkit-text-stroke: 1px rgba(232,0,61,0.35);"
              aria-hidden="true"
            >
              AG<br/>LA<br/>YA
            </div>
          </div>

        </div>
      </main>

      <!-- ══ MARQUEE ══ -->
      <section
        class="w-full shrink-0 py-3 overflow-hidden"
        style="border-top: 1px solid rgba(255,255,255,0.06);"
        aria-label="Services"
      >
        <div class="animate-marquee gap-12">
          <div class="flex items-center gap-12 text-[11px] md:text-xs font-black uppercase tracking-widest" style="color: rgba(245,245,245,0.35);">
            {marqueeItems.map((item) => (
              <>
                <span>{item}</span>
                <span style="color: #e8003d;">•</span>
              </>
            ))}
          </div>
          <div class="flex items-center gap-12 text-[11px] md:text-xs font-black uppercase tracking-widest" style="color: rgba(245,245,245,0.35);" aria-hidden="true">
            {marqueeItems.map((item) => (
              <>
                <span>{item}</span>
                <span style="color: #e8003d;">•</span>
              </>
            ))}
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>
