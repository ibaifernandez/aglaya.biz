---
import BaseLayout from '../layouts/BaseLayout.astro';

const pathname = Astro.url.pathname;
const isEs = pathname.startsWith('/es/') || pathname === '/es';

Astro.response.status = 404;

const copy = isEs
  ? {
      lang: 'es',
      title: 'AGLAYA — Página no encontrada',
      description: 'La página que buscas no existe.',
      heading: '404',
      sub: 'Página no encontrada.',
      body: 'La URL que introdujiste no existe o ha sido movida.',
      cta: 'Volver al inicio',
      ctaHref: '/es/',
    }
  : {
      lang: 'en',
      title: 'AGLAYA — Page not found',
      description: 'The page you are looking for does not exist.',
      heading: '404',
      sub: 'Page not found.',
      body: 'The URL you entered does not exist or has been moved.',
      cta: 'Back to home',
      ctaHref: '/',
    };
---

<BaseLayout title={copy.title} description={copy.description} lang={copy.lang}>
  <main id="main-content" class="not-found">
    <div class="nf-inner">
      <p class="nf-label">
        <span class="nf-line"></span>
        <span>AGLAYA</span>
      </p>
      <h1 class="nf-heading">{copy.heading}</h1>
      <p class="nf-sub">{copy.sub}</p>
      <p class="nf-body">{copy.body}</p>
      <a href={copy.ctaHref} class="nf-cta">
        {copy.cta}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
  </main>
</BaseLayout>

<style>
.not-found {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  background: #050505;
}

.nf-inner {
  max-width: 480px;
  text-align: center;
}

.nf-label {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  font-family: 'Outfit', sans-serif;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: #e8003d;
  margin: 0 0 2rem;
}
.nf-line {
  display: block;
  width: 2rem;
  height: 1px;
  background: #e8003d;
}

.nf-heading {
  font-family: 'Outfit', sans-serif;
  font-size: clamp(6rem, 20vw, 12rem);
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.05em;
  color: white;
  margin: 0 0 0.5rem;
}

.nf-sub {
  font-family: 'Outfit', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: white;
  margin: 0 0 1rem;
  text-transform: uppercase;
  letter-spacing: -0.02em;
}

.nf-body {
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  line-height: 1.6;
  color: rgba(255,255,255,0.5);
  margin: 0 0 2.5rem;
}

.nf-cta {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0.875rem 2rem;
  background: #e8003d;
  color: white;
  font-family: 'Outfit', sans-serif;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 2px;
  transition: transform 0.15s, box-shadow 0.2s;
}
.nf-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(232,0,61,0.4);
}
</style>
