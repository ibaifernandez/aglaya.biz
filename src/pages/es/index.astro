---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { useTranslations } from '../../i18n/translations';

const lang = 'es';
const t = useTranslations(lang);
const marqueeItems = [
  'Estrategia de Marca', 'Marketing Digital', 'Identidad Visual',
  'Diseño Web', 'Growth Hacking', 'Creación de Contenido',
  'Inteligencia de Marketing', 'Design Thinking',
];
---

<BaseLayout
  title={t('meta.title')}
  description={t('meta.description')}
  lang={lang}
>
  <style is:global>
    body { overflow: hidden; }
    h1, h2, h3, .font-display { font-family: 'Outfit', sans-serif; }
    ::-webkit-scrollbar { display: none; }
    .bg-grid {
      background-image:
        linear-gradient(rgba(232, 0, 61, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232, 0, 61, 0.04) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    @keyframes scanline {
      0% { transform: translateY(-100%); opacity: 0; }
      50% { opacity: 1; }
      100% { transform: translateY(100vh); opacity: 0; }
    }
    .scanner {
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--color-brand), transparent);
      animation: scanline 8s linear infinite;
    }
  </style>

    <!-- Header / Nav -->
    <header class="fixed top-0 inset-x-0 z-50 px-6 py-4 flex justify-between items-center backdrop-blur-md bg-black/20 border-b border-white/5"
              style="border-bottom: 1px solid rgba(255,255,255,0.06);"
              role="banner">
        <div class="flex flex-col justify-center gap-1">
          <img
            src="/assets/brand/aglaya-logo-blanco.svg"
            alt="AGLAYA"
            height="28"
            class="h-6 md:h-7 w-auto object-contain"
            loading="eager"
          />
          <span class="text-[8px] font-black tracking-[0.3em] text-muted uppercase pl-0.5">LA AGENCIA INCÓMODA</span>
        </div>

        <div class="flex items-center gap-4">
          <a href="/" lang="en" hreflang="en"
             class="lang-flag flex items-center gap-2 px-3 py-1.5 border border-white/10 hover:border-brand/40 transition-all text-[10px] font-black tracking-widest text-muted hover:text-white group"
             aria-label="View in English">
            <div class="w-4 h-4 rounded-full overflow-hidden border border-white/10 flex items-center justify-center shrink-0">
              <img src="/assets/brand/english.svg" alt="English" width="16" height="16" class="w-full h-full object-cover" loading="eager" />
            </div>
            <span>EN</span>
          </a>
          <a href="https://wa.me/573224288532"
             target="_blank"
             rel="noopener noreferrer"
             class="brand-cta bg-brand hover:bg-brand-hover text-white px-5 py-2 text-[10px] font-bold tracking-widest uppercase transition-all hover:scale-105 active:scale-95 flex items-center gap-2 rounded-sm shadow-[0_0_20px_rgba(232,0,61,0.3)]">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5" aria-hidden="true"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
            <span>WhatsApp</span>
          </a>
        </div>
    </header>

    <main class="relative min-h-screen bg-black text-white selection:bg-brand selection:text-white">

    <!-- Hero Section -->
    <section class="relative pt-40 pb-20 px-6 min-h-[90vh] flex flex-col justify-center items-center text-center z-30"
             aria-labelledby="hero-heading">
      <div class="max-w-5xl mx-auto">
        <div class="mb-8 flex flex-col items-center">
          <div class="h-px w-24 bg-brand mb-6"></div>
          <span class="text-xs font-black tracking-[0.5em] text-brand-light uppercase mb-4 decoration-brand/30 underline-offset-8 underline decoration-2">PRÓXIMAMENTE</span>
        </div>

        <h1 id="hero-heading" class="text-6xl md:text-9xl font-black tracking-tighter mb-12 leading-[0.85] uppercase">
          <span class="block text-white mb-2">La Agencia</span>
          <span class="block relative py-2">
            <span class="relative z-10 text-brand italic">Incómoda</span>
          </span>
        </h1>

        <div class="max-w-xl mx-auto mb-16">
          <p class="text-lg md:text-xl text-muted leading-relaxed font-light">
            Construimos marcas que convierten. Sin rellenos, sin excusas — solo resultados. Algo mejor está en camino.
          </p>
        </div>

        <div class="flex flex-col items-center gap-12">
          <div class="w-full max-w-md p-8 bg-white/5 border border-white/10 backdrop-blur-xl relative group rounded-sm shadow-2xl">
            <div class="absolute -inset-0.5 bg-gradient-to-r from-brand/20 to-purple-500/20 rounded-sm blur opacity-50 group-hover:opacity-100 transition duration-1000"></div>
            <div class="relative">
              <ContactForm lang={lang} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee Tech Stack -->
    <div class="fixed bottom-0 inset-x-0 z-40 bg-black/80 backdrop-blur-lg border-t border-white/5 py-4 overflow-hidden" role="complementary">
      <div class="flex whitespace-nowrap animate-marquee">
        {marqueeItems.concat(marqueeItems).map((item) => (
          <span class="text-[10px] font-black tracking-[0.4em] uppercase text-muted hover:text-brand transition-colors mx-8 block">
            {item}
          </span>
        ))}
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
  .text-brand { color: var(--color-brand); }
  .text-brand-light { color: #FF4D70; }
  .text-muted { color: rgba(255, 255, 255, 0.5); }
  .bg-brand { background-color: var(--color-brand); }
  .bg-black { background-color: #000; }
</style>
