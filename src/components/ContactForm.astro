---
import Mail from './icons/Mail.astro';
import User from './icons/User.astro';
import MessageSquare from './icons/MessageSquare.astro';
import Send from './icons/Send.astro';

interface Props {
  lang?: 'en' | 'es';
  turnstileSiteKey?: string;
}

const {
  lang = 'en',
  turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA',
} = Astro.props;

const labels = {
  en: {
    formLabel: 'Contact us',
    namePlaceholder: 'Your name',
    emailPlaceholder: 'your@email.com',
    messagePlaceholder: 'How can we help you?',
    submit: 'Send Message',
    success: "Message sent. We'll get back to you soon.",
    error: 'Something went wrong. Please try again.',
  },
  es: {
    formLabel: 'Contáctanos',
    namePlaceholder: 'Tu nombre',
    emailPlaceholder: 'tu@email.com',
    messagePlaceholder: '¿En qué podemos ayudarte?',
    submit: 'Enviar Mensaje',
    success: 'Mensaje enviado. Te contactaremos pronto.',
    error: 'Algo salió mal. Inténtalo de nuevo.',
  },
};

const t = labels[lang];
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<div class="w-full">
  <p id="contact-form-label" class="text-[10px] uppercase tracking-widest font-black mb-4 flex items-center gap-2"
     style="color: #e8003d">
    <span class="w-8 h-px bg-brand"></span>
    {t.formLabel}
  </p>

  <form
    id="contact-form"
    class="flex flex-col gap-4"
    novalidate
    aria-labelledby="contact-form-label"
  >
    <div class="relative group">
      <User class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-muted group-focus-within:text-brand transition-colors" />
      <input
        id="contact-name"
        type="text"
        name="name"
        placeholder={t.namePlaceholder}
        autocomplete="name"
        class="w-full pl-12 pr-4 py-3 text-sm font-medium border transition-all glass focus:outline-none focus:ring-1"
        style="border-color: rgba(255,255,255,0.12); color: #f5f5f5; focus-ring-color: #e8003d;"
      />
    </div>

    <div class="relative group">
      <Mail class="absolute left-4 top-1/2 -translate-y-1/2 w-4 h-4 text-muted group-focus-within:text-brand transition-colors" />
      <input
        id="contact-email"
        type="email"
        name="email"
        placeholder={t.emailPlaceholder}
        required
        autocomplete="email"
        class="w-full pl-12 pr-4 py-3 text-sm font-medium border transition-all glass focus:outline-none focus:ring-1"
        style="border-color: rgba(255,255,255,0.12); color: #f5f5f5; focus-ring-color: #e8003d;"
      />
    </div>

    <div class="relative group">
      <MessageSquare class="absolute left-4 top-4 w-4 h-4 text-muted group-focus-within:text-brand transition-colors" />
      <textarea
        id="contact-message"
        name="message"
        placeholder={t.messagePlaceholder}
        required
        rows="4"
        class="w-full pl-12 pr-4 py-3 text-sm font-medium border transition-all glass focus:outline-none focus:ring-1 resize-none"
        style="border-color: rgba(255,255,255,0.12); color: #f5f5f5; focus-ring-color: #e8003d;"
      ></textarea>
    </div>

    <div class="flex flex-col md:flex-row items-center gap-4">
      <button
        id="contact-submit"
        type="submit"
        class="w-full md:w-auto px-8 py-3 text-sm font-black uppercase tracking-widest text-white transition-all active:scale-95 flex items-center justify-center gap-2 disabled:opacity-50"
        style="background: #e8003d;"
      >
        <span id="contact-btn-text">{t.submit}</span>
        <Send class="w-4 h-4" />
      </button>

      <!-- Turnstile widget - integrated in the flow -->
      <div
        class="cf-turnstile scale-90 origin-left"
        data-sitekey={turnstileSiteKey}
        data-theme="dark"
        data-size="flexible"
        role="region"
        aria-label="Bot verification"
      ></div>
    </div>
  </form>

  <!-- Status messages -->
  <p id="contact-success" class="hidden mt-4 text-sm font-bold flex items-center gap-2" style="color:#4ade80" role="status" aria-live="polite">
    <span class="w-2 h-2 rounded-full bg-current animate-pulse"></span>
    {t.success}
  </p>
  <p id="contact-error" class="hidden mt-4 text-sm font-bold flex items-center gap-2" style="color:#f87171" role="alert" aria-live="assertive">
    <span class="w-2 h-2 rounded-full bg-current"></span>
    {t.error}
  </p>
</div>

<script>
  const form      = document.getElementById('contact-form') as HTMLFormElement | null;
  const nameInput = document.getElementById('contact-name') as HTMLInputElement | null;
  const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
  const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement | null;
  const successEl = document.getElementById('contact-success');
  const errorEl   = document.getElementById('contact-error');
  const btnText   = document.getElementById('contact-btn-text');
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !emailInput || !messageInput) return;

    const turnstileResponse = (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value ?? '';
    const email = emailInput.value.trim();
    const name = nameInput?.value.trim() ?? '';
    const message = messageInput.value.trim();

    if (!email || !message) return;

    const originalText = btnText?.textContent ?? '';
    if (btnText) btnText.textContent = '…';
    submitBtn.disabled = true;
    errorEl?.classList.add('hidden');

    try {
      const res = await fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message, token: turnstileResponse }),
      });

      if (res.ok) {
        form.style.display = 'none';
        successEl?.classList.remove('hidden');
        document.getElementById('contact-form-label')?.classList.add('hidden');
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error((data as {error?: string}).error ?? 'Error');
      }
    } catch {
      errorEl?.classList.remove('hidden');
      if (btnText) btnText.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
