---
interface Props {
  lang?: 'en' | 'es';
  turnstileSiteKey?: string;
}

const {
  lang = 'en',
  // Replace this with your Cloudflare Turnstile Site Key once created
  // https://dash.cloudflare.com/?to=/:account/turnstile
  turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '1x00000000000000000000AA', // test key
} = Astro.props;

const labels = {
  en: {
    formLabel: 'Get early access',
    placeholder: 'your@email.com',
    submit: 'Notify me',
    success: "You're in. We'll be in touch.",
    error: 'Something went wrong. Try again.',
    contact: 'Or reach us directly',
  },
  es: {
    formLabel: 'Acceso anticipado',
    placeholder: 'tu@email.com',
    submit: 'Avísame',
    success: 'Perfecto. Te contactaremos pronto.',
    error: 'Algo salió mal. Inténtalo de nuevo.',
    contact: 'O contáctanos directamente',
  },
};

const t = labels[lang];
---

<!-- Cloudflare Turnstile script (loaded once) -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<div class="w-full">
  <p id="lead-form-label" class="text-[10px] uppercase tracking-widest font-bold mb-2"
     style="color: rgba(245,245,245,0.45)">
    {t.formLabel}
  </p>

  <form
    id="lead-form"
    class="flex flex-col gap-3"
    novalidate
    aria-labelledby="lead-form-label"
  >
    <div class="flex flex-col sm:flex-row gap-2">
      <input
        id="lead-email"
        type="email"
        name="email"
        placeholder={t.placeholder}
        required
        autocomplete="email"
        aria-label={lang === 'en' ? 'Email address' : 'Correo electrónico'}
        class="flex-1 px-4 py-3 text-sm font-medium border focus:outline-none focus:ring-2 transition-all"
        style="background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.12); color: #f5f5f5; focus-ring-color: #e8003d;"
      />
      <button
        id="lead-submit"
        type="submit"
        class="px-6 py-3 text-sm font-black uppercase tracking-widest text-white transition-all active:scale-95 shrink-0 disabled:opacity-50"
        style="background: #e8003d;"
        aria-label={t.submit}
      >
        <span id="lead-btn-text">{t.submit}</span>
      </button>
    </div>

    <!-- Cloudflare Turnstile widget -->
    <div
      class="cf-turnstile"
      data-sitekey={turnstileSiteKey}
      data-theme="dark"
      data-size="flexible"
      role="region"
      aria-label="Bot verification"
    ></div>
  </form>

  <!-- Status messages -->
  <p id="lead-success" class="hidden mt-3 text-sm font-medium" style="color:#4ade80" role="status" aria-live="polite">
    {t.success}
  </p>
  <p id="lead-error" class="hidden mt-3 text-sm font-medium" style="color:#f87171" role="alert" aria-live="assertive">
    {t.error}
  </p>
</div>

<script>
  const form       = document.getElementById('lead-form') as HTMLFormElement | null;
  const emailInput = document.getElementById('lead-email') as HTMLInputElement | null;
  const successEl  = document.getElementById('lead-success');
  const errorEl    = document.getElementById('lead-error');
  const btnText    = document.getElementById('lead-btn-text');
  const submitBtn  = document.getElementById('lead-submit') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !emailInput) return;

    // Get Turnstile token
    const turnstileResponse = (form.querySelector('[name="cf-turnstile-response"]') as HTMLInputElement | null)?.value ?? '';

    const email = emailInput.value.trim();
    if (!email) return;

    const originalText = btnText?.textContent ?? '';
    if (btnText) btnText.textContent = '…';
    submitBtn.disabled = true;
    errorEl?.classList.add('hidden');

    try {
      const res = await fetch('/.netlify/functions/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, token: turnstileResponse }),
      });

      if (res.ok) {
        form.style.display = 'none';
        successEl?.classList.remove('hidden');
        document.getElementById('lead-form-label')?.classList.add('hidden');
      } else {
        const data = await res.json().catch(() => ({}));
        throw new Error((data as {error?: string}).error ?? 'Error');
      }
    } catch {
      errorEl?.classList.remove('hidden');
      if (btnText) btnText.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>
